# Slack
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-token

# Ollama (Local LLM — PRIMARY)
# Run Ollama server: ollama serve
# Pull the model: ollama pull qwen3.5:397b-cloud
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen3.5:397b-cloud

# OpenRouter (LLM gateway — FALLBACK, only if OLLAMA_BASE_URL not set)
OPENROUTER_API_KEY=sk-or-your-key
OPENROUTER_DEFAULT_MODEL=google/gemma-3-27b-it:free

# HubSpot (for MCP server + data seeding)
# Read scopes: crm.objects.contacts.read, crm.objects.companies.read, crm.objects.deals.read
# Write scopes (for seeding only): crm.objects.contacts.write, crm.objects.companies.write, crm.objects.deals.write
HUBSPOT_ACCESS_TOKEN=pat-your-private-app-token

# Tavily (web search — direct, not MCP)
TAVILY_API_KEY=tvly-your-key

# Google Cloud (for BigQuery MCP + Gmail MCP)
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
BIGQUERY_PROJECT_ID=your-gcp-project-id
BIGQUERY_DATASET=your-dataset-name

# Gmail OAuth (for Gmail MCP server)
GMAIL_CLIENT_ID=your-google-oauth-client-id
GMAIL_CLIENT_SECRET=your-google-oauth-client-secret

# Apollo.io Enrichment (optional — disabled by default for demo)
# Enable for real company lookups to get LinkedIn profiles, funding, tech stack
ENABLE_APOLLO_ENRICHMENT=false
APOLLO_API_KEY=your-apollo-api-key

# Auto-CRM Detection (Wave 1E)
# Comma-separated Slack channel IDs to monitor for auto-CRM suggestions
# Leave empty to disable auto-detect entirely
# Find channel IDs: right-click channel name in Slack → "Copy link" → ID is the last segment
AUTO_CRM_CHANNELS=

# Confidence threshold (0.0-1.0) — higher = fewer but more accurate suggestions
# Default 0.7 is a good starting point. Raise to 0.85 if reps find it too noisy.
AUTO_CRM_CONFIDENCE_THRESHOLD=0.7

# Cooldown in seconds between suggestions to the same user
# Default 60 prevents rapid-fire suggestions
AUTO_CRM_COOLDOWN_SECONDS=60
