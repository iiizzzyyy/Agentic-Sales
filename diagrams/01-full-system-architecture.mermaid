---
title: "Full System Architecture"
---
graph TB
    subgraph SLACK["SLACK WORKSPACE"]
        direction LR
        S1["Rep DMs bot"]
        S2["/coach command"]
        S3["/assist command"]
        S4["#pipeline channel"]
        S5["Thread replies"]
        S6["Button clicks"]
    end

    subgraph BOLT["SLACK BOLT SDK - Python"]
        B1["Event Handlers\nmessage, app_mention,\nslash_command, action"]
        B2["Middleware\nauth, rate limiting, logging"]
        B3["Response Formatter\nLangGraph output to Block Kit"]
    end

    subgraph ROUTER["ROUTER / TRIAGE\nLangGraph Subgraph"]
        R1["Parse Input"]
        R2["Classify Intent\nLLM: Claude Haiku 4.5"]
        R3["Route to Agent"]
    end

    subgraph COACH["COACH AGENT\nLangGraph Subgraph"]
        C1["Roleplay Workflow"]
        C2["Post-Call Feedback"]
        C3["Meeting Prep"]
        C_LLM["LLM: Claude Sonnet 4.5"]
    end

    subgraph ASSISTANT["ASSISTANT AGENT\nLangGraph Subgraph"]
        A1["Research Brief"]
        A2["CRM Update"]
        A3["Email Draft"]
        A4["Pipeline Health"]
        A_LLM["LLM: Gemini 2.5 Pro"]
    end

    subgraph TOOLS["SHARED TOOL LAYER via MCP"]
        T1["HubSpot MCP\nOfficial Beta"]
        T2["BigQuery MCP\nGoogle Managed"]
        T3["Gmail MCP\nCommunity"]
        T4["Web Search\nTavily"]
        T5["Vector DB - RAG\nQdrant/Weaviate"]
        T6["Memory Store\nPostgres/Redis"]
    end

    SLACK --> BOLT
    BOLT --> ROUTER
    R1 --> R2 --> R3
    R3 -->|"coaching/roleplay/feedback"| COACH
    R3 -->|"research/crm/email/pipeline"| ASSISTANT
    COACH --> TOOLS
    ASSISTANT --> TOOLS

    style SLACK fill:#4A154B,color:#fff
    style BOLT fill:#2C5F2D,color:#fff
    style ROUTER fill:#FF6B35,color:#fff
    style COACH fill:#6B5CE7,color:#fff
    style ASSISTANT fill:#0077B6,color:#fff
    style TOOLS fill:#2D3436,color:#fff
