---
title: "Router Agent - Intent Classification and Routing"
---
graph LR
    START((Start)) --> PARSE["Parse Input\nExtract text, user_id,\nchannel context"]
    PARSE --> CLASSIFY["Classify Intent\nClaude Haiku 4.5\n~100ms, ~$0.001"]
    CLASSIFY --> DECIDE{Intent?}

    DECIDE -->|"coaching / roleplay\nfeedback / training"| COACH["COACH\nSubgraph"]
    DECIDE -->|"research / crm\nemail / pipeline / admin"| ASSISTANT["ASSISTANT\nSubgraph"]
    DECIDE -->|"simple factual\nquestion"| DIRECT["Direct LLM\nAnswer"]
    DECIDE -->|"ambiguous /\nunclear"| CLARIFY["Ask User\nto Clarify"]

    COACH --> END_NODE((End))
    ASSISTANT --> END_NODE
    DIRECT --> END_NODE
    CLARIFY --> END_NODE

    style COACH fill:#6B5CE7,color:#fff
    style ASSISTANT fill:#0077B6,color:#fff
    style DIRECT fill:#2C5F2D,color:#fff
    style CLARIFY fill:#FF6B35,color:#fff
