%% ============================================================
%% DIAGRAM 7: RAG Pipeline — Indexing + Query
%% ============================================================

---
title: "RAG Pipeline — Indexing & Query Flow"
---
graph TB
    subgraph INDEXING["INDEXING PIPELINE (Scheduled / On-Trigger)"]
        direction LR
        SRC_PB["📄 Playbooks<br/><i>Manual upload</i>"]
        SRC_BC["⚔️ Battle Cards<br/><i>Manual upload</i>"]
        SRC_HS["🟠 HubSpot Notes<br/><i>Webhook / hourly</i>"]
        SRC_BQ["🔷 BigQuery Exports<br/><i>Daily scheduled</i>"]
        SRC_CT["🎙️ Call Transcripts<br/><i>After each call</i>"]
        SRC_PD["📦 Product Docs<br/><i>On release</i>"]

        CHUNK_R["Recursive Chunker<br/>400-512 tokens, 15% overlap<br/><i>For structured docs</i>"]
        CHUNK_S["Semantic Chunker<br/>Embedding-based splits<br/><i>For transcripts/notes</i>"]

        EMBED["Embedding Model<br/><b>Voyage AI 3.5</b><br/>1024 dims, int8"]

        VDB_IDX["Vector DB<br/><b>Qdrant / Weaviate</b><br/>Hybrid index"]
    end

    SRC_PB & SRC_BC & SRC_PD --> CHUNK_R
    SRC_HS & SRC_CT --> CHUNK_S
    SRC_BQ --> CHUNK_R
    CHUNK_R & CHUNK_S --> EMBED --> VDB_IDX

    subgraph QUERY["QUERY PIPELINE (Every Agent Request)"]
        direction LR
        Q_INPUT["User Query<br/><i>from Slack</i>"]
        Q_EMBED["Embed Query<br/><b>Voyage AI 3.5</b>"]
        Q_HYBRID["Hybrid Search<br/>Vector + BM25<br/>Top 50 results"]
        Q_RERANK["Reranker<br/><b>Cohere Rerank v4</b><br/>Top 5 results"]
        Q_INJECT["Inject into<br/>LLM context<br/>as system message"]
    end

    Q_INPUT --> Q_EMBED --> Q_HYBRID --> Q_RERANK --> Q_INJECT
    VDB_IDX -.->|serves| Q_HYBRID

    style INDEXING fill:#1B4332,color:#fff
    style QUERY fill:#2D3436,color:#fff


%% ============================================================
%% DIAGRAM 8: Memory Architecture (4 Layers)
%% ============================================================

---
title: "4-Layer Memory Architecture"
---
graph TB
    subgraph L1["Layer 1: CONVERSATION MEMORY"]
        L1_STORE["LangGraph Checkpointer<br/>(Postgres / Redis)"]
        L1_CONTENT["Full message history<br/>Agent state mid-workflow<br/>Roleplay scores in progress"]
        L1_MAP["Slack thread_ts → LangGraph thread_id"]
        L1_LIFE["Lifetime: Duration of thread/session"]
    end

    subgraph L2["Layer 2: REP PROFILE MEMORY"]
        L2_STORE["Postgres / BigQuery"]
        L2_CONTENT["Skill scores per competency<br/>Weak areas & coaching history<br/>Preferred coaching style<br/>Completed roleplays & ratings"]
        L2_MAP["Slack user_id → rep profile record"]
        L2_LIFE["Lifetime: Persistent (grows over time)"]
    end

    subgraph L3["Layer 3: TEAM KNOWLEDGE"]
        L3_STORE["Vector DB<br/>(Qdrant / Weaviate)"]
        L3_CONTENT["Playbooks & battle cards<br/>Call transcripts & best practices<br/>Deal patterns & win/loss analysis<br/>ICP definitions"]
        L3_MAP["Accessed via RAG at query time"]
        L3_LIFE["Lifetime: Persistent, updated on schedule"]
    end

    subgraph L4["Layer 4: LIVE DATA"]
        L4_STORE["External APIs via MCP"]
        L4_CONTENT["Current deal status (HubSpot)<br/>Latest emails (Gmail)<br/>Fresh analytics (BigQuery)<br/>Company news (Web Search)"]
        L4_MAP["Accessed via MCP tool calls"]
        L4_LIFE["Lifetime: Real-time / short TTL cache"]
    end

    L1 ---|per request| AGENT["Agent<br/>Runtime"]
    L2 ---|per session start| AGENT
    L3 ---|per RAG query| AGENT
    L4 ---|per tool call| AGENT

    style L1 fill:#6B5CE7,color:#fff
    style L2 fill:#0077B6,color:#fff
    style L3 fill:#1B4332,color:#fff
    style L4 fill:#FF6B35,color:#fff


