%% ============================================================
%% SALES AI AGENTS — ARCHITECTURE DIAGRAMS (Mermaid)
%% All wiring details for the Slack-based Coach & Assistant agents
%% ============================================================


%% ============================================================
%% DIAGRAM 1: Full System Architecture (Top-Level)
%% ============================================================

---
title: "Full System Architecture"
---
graph TB
    subgraph SLACK["SLACK WORKSPACE"]
        direction LR
        S1["Rep DMs bot"]
        S2["/coach command"]
        S3["/assist command"]
        S4["#pipeline channel"]
        S5["Thread replies"]
        S6["Button clicks"]
    end

    subgraph BOLT["SLACK BOLT SDK (Python)"]
        B1["Event Handlers<br/>message, app_mention,<br/>slash_command, action"]
        B2["Middleware<br/>auth, rate limiting, logging"]
        B3["Response Formatter<br/>LangGraph output → Block Kit"]
    end

    subgraph TRIAGE["HIVE MIND TRIAGE<br/>LangGraph Subgraph"]
        T1["Parse Input"]
        T2["Classify Complexity<br/><b>LLM: qwen3.5:397b-cloud</b>"]
        T3["Route: DIRECT/WORKFLOW/COMPLEX"]
    end

    subgraph COACH["COACH AGENT<br/>LangGraph Subgraph (Typed)"]
        C1["Roleplay Workflow"]
        C2["Post-Call Feedback"]
        C3["Meeting Prep"]
        C_LLM["<b>LLM: qwen3.5:397b-cloud</b>"]
    end

    subgraph ASSISTANT["ASSISTANT AGENT<br/>LangGraph Subgraph (Typed)"]
        A1["Research Brief"]
        A2["CRM Update"]
        A3["Email Draft"]
        A4["Pipeline Health"]
        A_LLM["<b>LLM: qwen3.5:397b-cloud</b>"]
    end

    subgraph HIVEMIND["HIVE MIND ORCHESTRATION"]
        PM["PM Agent<br/>Task Decomposition"]
        DAG["DAG Executor<br/>Parallel Batches"]
        REV["Reviewer<br/>Quality Check"]
    end

    subgraph TOOLS["SHARED TOOL LAYER (via MCP)"]
        T1["HubSpot MCP<br/>Official Beta"]
        T2["BigQuery MCP<br/>Google Managed"]
        T3["Gmail MCP<br/>Community"]
        T4["Web Search<br/>Tavily"]
        T5["Vector DB (RAG)<br/>Qdrant/Weaviate"]
        T6["Memory Store<br/>Postgres/Redis"]
    end

    SLACK --> BOLT
    BOLT --> TRIAGE
    T1 --> T2 --> T3
    T3 -->|DIRECT| TOOLS
    T3 -->|WORKFLOW| COACH
    T3 -->|COMPLEX| HIVEMIND
    COACH --> TOOLS
    ASSISTANT --> TOOLS
    PM --> DAG --> REV
    HIVEMIND --> TOOLS

    style SLACK fill:#4A154B,color:#fff
    style BOLT fill:#2C5F2D,color:#fff
    style ROUTER fill:#FF6B35,color:#fff
    style COACH fill:#6B5CE7,color:#fff
    style ASSISTANT fill:#0077B6,color:#fff
    style TOOLS fill:#2D3436,color:#fff


%% ============================================================
%% DIAGRAM 2: Slack → LangGraph Connection Flow
%% ============================================================

---
title: "Slack ↔ LangGraph Connection Flow"
---
sequenceDiagram
    participant Rep as Sales Rep
    participant Slack as Slack Workspace
    participant Bolt as Slack Bolt SDK
    participant LG as LangGraph Runtime
    participant CP as Checkpointer<br/>(Postgres)
    participant Router as Router Agent<br/>(Haiku)
    participant Coach as Coach Agent<br/>(Claude Sonnet)
    participant Asst as Assistant Agent<br/>(Gemini)
    participant MCP as MCP Tool Servers

    Rep->>Slack: /coach roleplay discovery call
    Slack->>Bolt: HTTP Event / Socket Mode
    Bolt->>Bolt: ack() + typing indicator

    Bolt->>LG: graph.ainvoke(messages, config={thread_id})
    LG->>CP: Load state for thread_id
    CP-->>LG: Previous state (or empty)

    LG->>Router: Classify intent
    Router-->>LG: route = "coach"

    LG->>Coach: Execute coach subgraph
    Coach->>MCP: RAG retrieval (playbooks, ICP)
    MCP-->>Coach: Relevant context chunks
    Coach->>MCP: HubSpot (deal context)
    MCP-->>Coach: Deal data
    Coach-->>LG: Generated roleplay response

    LG->>CP: Persist updated state
    LG-->>Bolt: Result message

    Bolt->>Slack: say(text, thread_ts)
    Slack->>Rep: Buyer persona response in thread

    Note over Rep,Slack: Rep thinks... replies in thread
    Rep->>Slack: Thread reply with sales pitch

    Slack->>Bolt: message event (thread)
    Bolt->>LG: graph.ainvoke(new_message, same thread_id)
    LG->>CP: Load persisted state (mid-roleplay)
    CP-->>LG: Full roleplay state restored
    LG->>Coach: Resume at "score rep's turn" node
    Coach-->>LG: Score + next buyer response
    LG->>CP: Persist updated state
    LG-->>Bolt: Next turn response
    Bolt->>Slack: say(response, thread_ts)
    Slack->>Rep: Next roleplay turn


%% ============================================================
%% DIAGRAM 3: Hive Mind Triage Graph
%% ============================================================

---
title: "Hive Mind Triage — Complexity Classification & Routing"
---
graph LR
    START((Start)) --> PARSE["Parse Input<br/>Extract text, user_id,<br/>channel context"]
    PARSE --> CLASSIFY["Classify Complexity<br/><b>qwen3.5:397b-cloud</b><br/>Local inference"]
    CLASSIFY --> DECIDE{Complexity?}

    DECIDE -->|DIRECT<br/>single lookup| DIRECT["Direct Executor<br/>Single tool call"]
    DECIDE -->|WORKFLOW<br/>single workflow| COACH["COACH<br/>Subgraph"]
    DECIDE -->|COMPLEX<br/>multi-step| PM["PM Agent<br/>Task Decomposition"]
    DECIDE -->|ambiguous /<br/>unclear| CLARIFY["Ask User<br/>to Clarify"]

    DIRECT --> END((End))
    COACH --> END((End))
    PM --> DAG["DAG Executor<br/>Parallel Batches"]
    DAG --> REV["Reviewer<br/>Quality Gate"]
    REV --> END((End))
    CLARIFY --> END((End))

    style DIRECT fill:#2C5F2D,color:#fff
    style COACH fill:#6B5CE7,color:#fff
    style PM fill:#FF6B35,color:#fff
    style DAG fill:#A78BFA,color:#fff
    style REV fill:#EF4444,color:#fff


%% ============================================================
%% DIAGRAM 4: Coach Agent Graph (Detailed Workflows)
%% ============================================================

---
title: "Coach Agent — Detailed Workflow Graph"
---
graph TB
    START((Start)) --> CLASSIFY_REQ["Classify Request Type"]
    CLASSIFY_REQ --> LOAD_PROFILE["Load Rep Profile<br/>(Postgres/BigQuery)"]
    LOAD_PROFILE --> CHOOSE{Choose Workflow}

    CHOOSE -->|roleplay request| RP_START["ROLEPLAY WORKFLOW"]
    CHOOSE -->|call feedback| PC_START["POST-CALL FEEDBACK"]
    CHOOSE -->|meeting prep| PREP_START["PREP WORKFLOW"]

    subgraph ROLEPLAY["Roleplay Workflow"]
        RP_START --> RP_RAG["RAG: Pull ICP,<br/>objections, battle cards"]
        RP_RAG --> RP_PERSONA["Generate Buyer Persona<br/><b>Claude Sonnet 4.5</b>"]
        RP_PERSONA --> RP_BUYER["Generate Buyer Response"]
        RP_BUYER --> RP_SEND["Send to Slack as Buyer"]
        RP_SEND --> RP_WAIT["⏸️ WAIT for Rep Reply<br/><i>Durable execution:<br/>graph pauses, state persists</i>"]
        RP_WAIT --> RP_SCORE["Score Rep's Turn<br/><b>Claude Sonnet 4.5</b>"]
        RP_SCORE --> RP_CHECK{More turns?}
        RP_CHECK -->|yes| RP_BUYER
        RP_CHECK -->|no| RP_DEBRIEF["Generate Final Debrief<br/>Scores + Action Items"]
    end

    subgraph POSTCALL["Post-Call Feedback"]
        PC_START --> PC_RAG1["RAG: Pull call<br/>transcript/notes"]
        PC_RAG1 --> PC_RAG2["RAG: Pull playbook<br/>scoring criteria"]
        PC_RAG2 --> PC_SCORE["Score Against Rubric<br/><b>Claude Sonnet 4.5</b>"]
        PC_SCORE --> PC_ACTIONS["Generate Action Items"]
        PC_ACTIONS --> PC_UPDATE["Update Rep Skill Profile"]
    end

    subgraph MEETPREP["Meeting Prep"]
        PREP_START --> PREP_HS["HubSpot: Get Deal<br/>+ Contact History"]
        PREP_HS --> PREP_RAG["RAG: Pull Playbook<br/>Section"]
        PREP_RAG --> PREP_WEB["Web Search: Company<br/>News + Intel"]
        PREP_WEB --> PREP_BQ["BigQuery: Historical<br/>Deal Patterns"]
        PREP_BQ --> PREP_GEN["Generate Prep Brief<br/><b>Claude Sonnet 4.5</b>"]
    end

    RP_DEBRIEF --> UPDATE_PROFILE
    PC_UPDATE --> UPDATE_PROFILE
    PREP_GEN --> FORMAT

    UPDATE_PROFILE["Update Rep Profile<br/>(Postgres/BigQuery)"] --> FORMAT["Format & Return<br/>to Slack"]
    FORMAT --> END_NODE((End))

    style ROLEPLAY fill:#6B5CE7,color:#fff
    style POSTCALL fill:#8B5CF6,color:#fff
    style MEETPREP fill:#A78BFA,color:#fff
    style RP_WAIT fill:#FF6B35,color:#fff


